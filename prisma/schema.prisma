generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SurveyStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum QuestionType {
  CHOICE
  TEXT
}

model User {
  id         String      @id @default(uuid())
  name       String
  email      String      @unique
  password   String?
  surveys    Survey[]
  emailLists EmailList[]
}

model Survey {
  id           String       @id @default(uuid())
  title        String
  description  String?
  slug         String       @unique
  status       SurveyStatus @default(DRAFT)
  createdAt    DateTime     @default(now())
  publishedAt  DateTime?
  closedAt     DateTime?
  ownerId      String
  owner        User         @relation(fields: [ownerId], references: [id])
  questions    Question[]
  invitations  Invitation[]
  responses    Response[]
}

model Question {
  id            String          @id @default(uuid())
  surveyId      String
  survey        Survey          @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  title         String
  type          QuestionType
  required      Boolean         @default(false)
  maxSelections Int?
  maxLength     Int?            @default(1000)
  order         Int?
  options       QuestionOption[]
  answersChoice AnswerChoice[]
  answersText   AnswerText[]
}

model QuestionOption {
  id            String         @id @default(uuid())
  questionId    String
  question      Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  label         String
  order         Int
  answerChoices AnswerChoice[]
}

model EmailList {
  id            String         @id @default(uuid())
  ownerId       String
  owner         User           @relation(fields: [ownerId], references: [id])
  name          String
  createdAt     DateTime       @default(now())
  emailContacts EmailContact[]
}

model EmailContact {
  id            String       @id @default(uuid())
  emailListId   String
  emailList     EmailList    @relation(fields: [emailListId], references: [id], onDelete: Cascade)
  email         String
  name          String?
  createdAt     DateTime     @default(now())
  invitations   Invitation[]
}

model Invitation {
  id              String        @id @default(uuid())
  surveyId        String
  survey          Survey        @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  contactId       String
  contact         EmailContact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tokenHash       String
  sentAt          DateTime
  emailOpenedAt   DateTime?
  surveyOpenedAt  DateTime?
  bouncedAt       DateTime?
  submittedAt     DateTime?
  response        Response?

  @@unique([surveyId, contactId])
  @@index([tokenHash])
}

model Response {
  id            String        @id @default(uuid())
  surveyId      String
  survey        Survey        @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  invitationId  String        @unique
  invitation    Invitation    @relation(fields: [invitationId], references: [id])
  submittedAt   DateTime      @default(now())
  answersChoice AnswerChoice[]
  answersText   AnswerText[]
}

model AnswerChoice {
  id         String          @id @default(uuid())
  responseId String
  response   Response        @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId String
  question   Question        @relation(fields: [questionId], references: [id], onDelete: NoAction)
  optionId   String
  option     QuestionOption  @relation(fields: [optionId], references: [id], onDelete: Cascade)
}

model AnswerText {
  id         String   @id @default(uuid())
  responseId String
  response   Response @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: NoAction)
  textValue  String
}